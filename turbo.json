{
    "$schema": "https://turborepo.org/schema.json",
    "pipeline": {
      "preview": {
        "cache": false,
        "persistent": true,
        "dependsOn": ["build"]
      },
      "test:ssr": {
        "cache": true,
        "inputs": [
          "$TURBO_DEFAULT$",
          "../playwright.config.ts",
          "../playwright-helpers/**",
          "../package.json",
          "../test/playwright/**",
          "../test/ssr/**",
          "../turbo.json",
          "../yarn.lock"
        ]
      },
      "test:system": {
        "cache": true,
        "inputs": [
          "$TURBO_DEFAULT$",
          "./playwright.config.ts",
          "../playwright-helpers/**",
          "../package.json",
          "../test/playwright/**",
          "../test/system/**",
          "../turbo.json",
          "../yarn.lock"
        ]
      },
      "playwright:show-report": {
        "cache": false
      },
      "test:visual": {
        "cache": false
      },
      "test:visual:playwright": {
        "cache": false,
        "inputs": [
          "$TURBO_DEFAULT$",
          "../package.json",
          "../playwright.percy.config.ts",
          "../playwright-helpers/**",
          "../test/playwright/**",
          "../turbo.json",
          "../yarn.lock"
        ]
      },
      "test:visual:chromatic": {
        "cache": false
      },
      "dev": {
        "cache": false,
        "persistent": true
      },
      "upgrade-pie-packages": {
        "cache": false
      }
    }
}
